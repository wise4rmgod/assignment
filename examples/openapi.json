{
  "openapi": "3.0.3",
  "info": {
    "title": "Canton Participant Node API",
    "description": "API for onboarding a user to a Canton network by allocating a Party, submitting a command, and querying active contracts.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://your-canton-node.example.com",
      "description": "Canton Participant Node"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AllocatePartyRequest": {
        "type": "object",
        "required": ["party_hint"],
        "properties": {
          "party_hint": {
            "type": "string",
            "example": "Alice",
            "description": "A human-readable label used as a hint when generating the Party ID. This helps identify the Party but does not need to be unique."
          }
        }
      },
      "AllocatePartyResponse": {
        "type": "object",
        "properties": {
          "party": {
            "type": "string",
            "example": "Alice::1220f3a9c8e4b7...",
            "description": "The globally unique Party ID generated by the Canton Participant Node. This value is required for all subsequent interactions."
          }
        }
      },
      "SubmitCommandRequest": {
        "type": "object",
        "required": ["party", "commands", "timeout"],
        "properties": {
          "party": {
            "type": "string",
            "example": "Alice::1220f3a9c8e4b7...",
            "description": "The unique Party ID on whose behalf the transaction is being submitted. This Party must have the necessary permissions."
          },
          "commands": {
            "type": "object",
            "description": "Container for the command payload to be executed on the ledger.",
            "required": ["signed_transaction"],
            "properties": {
              "signed_transaction": {
                "type": "string",
                "example": "<SIGNED_TRANSACTION_PAYLOAD>",
                "description": "A cryptographically signed transaction payload that defines the action to perform (such as creating or updating a contract). This ensures the request is authorized and tamper-proof."
              }
            }
          },
          "timeout": {
            "type": "integer",
            "example": 30,
            "description": "The maximum number of seconds the server should wait for the transaction to complete before returning a timeout response."
          }
        }
      },
      "SubmitCommandResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success",
            "description": "Indicates whether the transaction was successfully processed."
          },
          "transaction_id": {
            "type": "string",
            "example": "abc123xyz",
            "description": "A unique identifier for the submitted transaction, which can be used for tracking or debugging."
          }
        }
      },
      "ActiveContractsRequest": {
        "type": "object",
        "required": ["party"],
        "properties": {
          "party": {
            "type": "string",
            "example": "Alice::1220f3a9c8e4b7...",
            "description": "The Party ID whose visible active contracts should be returned. Only contracts accessible to this Party will be included in the response."
          }
        }
      },
      "Contract": {
        "type": "object",
        "properties": {
          "contract_id": {
            "type": "string",
            "example": "00ab34cd...",
            "description": "The unique identifier of the contract instance on the ledger."
          },
          "template_id": {
            "type": "string",
            "example": "MyApp:Agreement",
            "description": "The identifier of the contract template used to create this contract."
          },
          "payload": {
            "type": "object",
            "additionalProperties": true,
            "description": "The contract data containing business-specific fields defined by the template.",
            "example": {
              "owner": "Alice",
              "status": "ACTIVE"
            }
          }
        }
      },
      "ActiveContractsResponse": {
        "type": "object",
        "properties": {
          "contracts": {
            "type": "array",
            "description": "A list of active contracts visible to the specified Party.",
            "items": {
              "$ref": "#/components/schemas/Contract"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Unauthorized",
            "description": "Short error type or code."
          },
          "message": {
            "type": "string",
            "example": "Invalid or missing JWT token",
            "description": "Detailed explanation of the error."
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/v2/parties/allocate": {
      "post": {
        "summary": "Allocate a new Party",
        "description": "Creates a new Party identity on the Canton Participant Node.",
        "operationId": "allocateParty",
        "requestBody": {
          "required": true,
          "description": "Request to create a new Party identity.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AllocatePartyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Party successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllocatePartyResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/commands/submitUntilTimeout": {
      "post": {
        "summary": "Submit a command (transaction)",
        "description": "Submits a signed transaction on behalf of a Party and waits for completion.",
        "operationId": "submitCommand",
        "requestBody": {
          "required": true,
          "description": "Request to submit a signed transaction for execution.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitCommandRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction successfully submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitCommandResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/state/active-contracts": {
      "post": {
        "summary": "Query active contracts",
        "description": "Returns all active contracts visible to a specific Party.",
        "operationId": "getActiveContracts",
        "requestBody": {
          "required": true,
          "description": "Request to retrieve active contracts for a given Party.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActiveContractsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of active contracts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ActiveContractsResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}